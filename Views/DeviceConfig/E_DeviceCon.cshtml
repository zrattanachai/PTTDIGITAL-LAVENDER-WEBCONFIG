            document.getElementById("txtbaudrate").value = null;
            return false;
        }

        if (document.getElementById("txtread").value >= 0 && document.getElementById("txtread").value.match(regexnumbers))
        {
            stringArray[5] = document.getElementById("txtread").value;
        }
        else
        {
            $.bsAlert.alert("Read Timeout is a number and no less than 0.");
            document.getElementById("txtread").value = null;
            return false;
        }

        if (document.getElementById("txtreaddata").value >= 0 && document.getElementById("txtreaddata").value.match(regexnumbers))
