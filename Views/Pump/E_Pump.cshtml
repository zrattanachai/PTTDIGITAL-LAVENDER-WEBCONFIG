                                                    });
                                                }
                                                @Html.DropDownList("value_decimal_digit", new SelectList(PumpDisNonTotListItems, "Value", "Text", item.value_decimal_digit)
                                                , new { @class = "form-control", /*id = "value_decimal_digit",*/ @onchange = "defaultValTotal(this.value)" })
                                                @Html.HiddenFor(x => item.value_decimal_digit, new { id = "txtPumpDisVal" })
                                            </div>
                                        </div>
                                        <br>
                                        <div class="row clearfix">
                                            <div class="col-md-1"></div>
                                            <div class="col-md-4">@Html.LabelFor(model => item.volume_decimal_digit, "Pump Volume Format: ", new { @class = "normalweight" })</div>
                                            <div class="col-md-3">
                                                @Html.DropDownList("volume_decimal_digit", new SelectList(PumpDisNonTotListItems, "Value", "Text", item.volume_decimal_digit)
                                                , new { @class = "form-control", /*id = "volume_decimal_digit",*/ @onchange = "defaultVolTotal(this.value)" })
                                                @Html.HiddenFor(x => item.volume_decimal_digit, new { id = "txtPumpDisVol" })
                                            </div>
                                        </div>
                                        <br>
                                        <div class="row clearfix">
                                            <div class="col-md-1"></div>
                                            <div class="col-md-4">@Html.LabelFor(model => item.price_decimal_digit, "Price Format: ", new { @class = "normalweight" })</div>
                                            <div class="col-md-3">
                                                @Html.DropDownList("price_decimal_digit", new SelectList(PumpDisNonTotListItems, "Value", "Text", item.price_decimal_digit)
                                                , new { @class = "form-control", /*id = "price_decimal_digit",*/ @onchange = "dispritohidden()" })
                                                @Html.HiddenFor(x => item.price_decimal_digit, new { id = "txtPumpDisPri" })
                                            </div>
                                        </div>
                                        <br>
                                        <div class="row clearfix">
                                            <div class="col-md-1"></div>
                                            <div class="col-md-4">@Html.LabelFor(model => item.value_total_decimal_digit, "Total Value Format: ", new { @class = "normalweight" })</div>
                                            <div class="col-md-3">
                                                @{
                                                    List<SelectListItem> PumpDisTotListItems = new List<SelectListItem>();
                                                    PumpDisTotListItems.Add(new SelectListItem
                                                    {
                                                        Text = "0",
                                                        Value = "0"
                                                    });
                                                    PumpDisTotListItems.Add(new SelectListItem
                                                    {
                                                        Text = "0.0",
                                                        Value = "1"
                                                    });
                                                    PumpDisTotListItems.Add(new SelectListItem
                                                    {
                                                        Text = "0.00",
                                                        Value = "2"
                                                    });
                                                    PumpDisTotListItems.Add(new SelectListItem
                                                    {
                                                        Text = "0.000",
                                                        Value = "3"
                                                    });
                                                }
                                                @Html.DropDownList("value_total_decimal_digit", new SelectList(PumpDisTotListItems, "Value", "Text", item.value_total_decimal_digit)
                                                , new { @class = "form-control", /*id = "value_total_decimal_digit",*/ @onchange = "disvaltottohidden()" })
                                                @Html.HiddenFor(x => item.value_total_decimal_digit, new { id = "txtPumpDisValTot" })
                                            </div>
                                        </div>
                                        <br>
                                        <div class="row clearfix">
                                            <div class="col-md-1"></div>
                                            <div class="col-md-4">@Html.LabelFor(model => item.volume_total_decimal_digit, "Total Volume Format: ", new { @class = "normalweight" })</div>
                                            <div class="col-md-3">
                                                @Html.DropDownList("volume_total_decimal_digit", new SelectList(PumpDisTotListItems, "Value", "Text", item.volume_total_decimal_digit)
                                                , new { @class = "form-control", /*id = "volume_total_decimal_digit",*/ @onchange = "disvoltottohidden()" })
                                                @Html.HiddenFor(x => item.volume_total_decimal_digit, new { id = "txtPumpDisVolTot" })
                                            </div>
                                        </div>
                                        
                                        <br>
                                        <div class="row clearfix">
                                            <div class="col-md-1"></div>
                                            <div class="col-md-4">@Html.LabelFor(model => item.stack_limit, "Stack Size: ", new { @class = "normalweight" })</div>
                                            <div class="col-md-3">
                                                @Html.TextBox("stack_limit", item.stack_limit, new { id = "txtStackSize", required = "required", type = "number", min = 1, max = 200, placeholder = "1 -> 200", @class = "form-control" })
                                            </div>
                                        </div>
                                    
                                        <br>
                                        <div class="row clearfix">
                                            <div class="col-md-1"></div>
                                            <div class="col-md-4">@Html.LabelFor(model => item.self_mode, "Enable Self Authorize Feature: ", new { @class = "normalweight" })</div>
                                            <div class="col-md-3">
                                                <div class="custom-control custom-switch custom-switch-lg">
                                                    @if (item.self_mode == true)
                                                    {
                                                        @Html.CheckBoxFor(model => item.self_mode, new { @id = "chkSelfAutho", @checked = "checked", @class = "custom-control-input" })
                                                        <label class="custom-control-label" for="chkSelfAutho"></label>
                                                    }
                                                    else
                                                    {
                                                        @Html.CheckBoxFor(model => item.self_mode, new { @id = "chkSelfAutho", @class = "custom-control-input" })
                                                        <label class="custom-control-label" for="chkSelfAutho"></label>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                        <div class="row clearfix">
                                            <div class="col-md-1"></div>
                                            <div class="col-sm-2" id="openadset">
                                                <button type="button" class="btn btn-block btn-outline-primary" onclick="hideAdSetting()"><i class="fas fa-angle-right"></i>&nbsp; Advance Setting</button>
                                            </div>
                                            <div class="col-sm-2" id="closeadset" style="display:none">
                                                <button type="button" class="btn btn-block btn-outline-primary" onclick="hideAdSetting()"><i class="fas fa-angle-down"></i>&nbsp; Advance Setting</button>
                                            </div>
                                        </div>
                                        <br>
                                        <div class="row clearfix" id="divadset">
                                            <div class="row clearfix">
                                                <div class="col-md-1"></div>
                                                <div class="col-md-4" style="margin-left:0.5%">@Html.LabelFor(model => item.multipier_preset_volume, "Multiplier preset volume: ", new { @class = "normalweight" })</div>
                                                <div class="col-md-3">
                                                    @{
                                                        List<SelectListItem> AdvSetListItems = new List<SelectListItem>();
                                                        AdvSetListItems.Add(new SelectListItem
                                                        {
                                                            Text = "1000",
                                                            Value = "1000"
                                                        });
                                                        AdvSetListItems.Add(new SelectListItem
                                                        {
                                                            Text = "100",
                                                            Value = "100"
                                                        });
                                                        AdvSetListItems.Add(new SelectListItem
                                                        {
                                                            Text = "10",
                                                            Value = "10"
                                                        });
                                                        AdvSetListItems.Add(new SelectListItem
                                                        {
                                                            Text = "1",
                                                            Value = "1"
                                                        });
                                                        AdvSetListItems.Add(new SelectListItem
                                                        {
                                                            Text = "0.1",
                                                            Value = "0.1"
                                                        });
                                                        AdvSetListItems.Add(new SelectListItem
                                                        {
                                                            Text = "0.01",
                                                            Value = "0.01"
                                                        });
                                                        AdvSetListItems.Add(new SelectListItem
                                                        {
                                                            Text = "0.001",
                                                            Value = "0.001"
                                                        });
                                                    }
                                                    @Html.DropDownList("multipier_preset_volume", new SelectList(AdvSetListItems, "Value", "Text", item.multipier_preset_volume)
                                                    , new { @class = "form-control", /*id = "multipier_preset_volume",*/ })
                                                </div>
                                            </div>
                                            <br>
                                            <div class="row clearfix">
                                                <div class="col-md-1"></div>
                                                <div class="col-md-4" style="margin-left:0.5%">@Html.LabelFor(model => item.multipier_preset_value, "Multiplier preset value: ", new { @class = "normalweight" })</div>
                                                <div class="col-md-3">
                                                    @Html.DropDownList("multipier_preset_value", new SelectList(AdvSetListItems, "Value", "Text", item.multipier_preset_value)
                                                    , new { @class = "form-control", /*id = "volume_total_decimal_digit",*/ })
                                                </div>
                                            </div>
                                            <br>
                                            <div class="row clearfix">
                                                <div class="col-md-1"></div>
                                                <div class="col-md-4" style="margin-left:0.5%">@Html.LabelFor(model => item.multipier_transaction_volume, "Multiplier transaction volume: ", new { @class = "normalweight" })</div>
                                                <div class="col-md-3">
                                                    @Html.DropDownList("multipier_transaction_volume", new SelectList(AdvSetListItems, "Value", "Text", item.multipier_transaction_volume)
                                                    , new { @class = "form-control", /*id = "multipier_transaction_volume",*/ })
                                                </div>
                                            </div>
                                            <br>
                                            <div class="row clearfix">
                                                <div class="col-md-1"></div>
                                                <div class="col-md-4" style="margin-left:0.5%">@Html.LabelFor(model => item.multipier_transaction_value, "Multiplier transaction value: ", new { @class = "normalweight" })</div>
                                                <div class="col-md-3">
                                                    @Html.DropDownList("multipier_transaction_value", new SelectList(AdvSetListItems, "Value", "Text", item.multipier_transaction_value)
                                                    , new { @class = "form-control", /*id = "multipier_transaction_value",*/ })
                                                </div>
                                            </div>
                                            <br>
                                            <div class="row clearfix">
                                                <div class="col-md-1"></div>
                                                <div class="col-md-4" style="margin-left:0.5%">@Html.LabelFor(model => item.multipier_total_volume, "Multiplier total volume: ", new { @class = "normalweight" })</div>
                                                <div class="col-md-3">
                                                    @Html.DropDownList("multipier_total_volume", new SelectList(AdvSetListItems, "Value", "Text", item.multipier_total_volume)
                                                    , new { @class = "form-control", /*id = "multipier_total_volume",*/ })
                                                </div>
                                            </div>
                                            <br>
                                            <div class="row clearfix">
                                                <div class="col-md-1"></div>
                                                <div class="col-md-4" style="margin-left:0.5%">@Html.LabelFor(model => item.multipier_total_value, "Multiplier total value: ", new { @class = "normalweight" })</div>
                                                <div class="col-md-3">
                                                    @Html.DropDownList("multipier_total_value", new SelectList(AdvSetListItems, "Value", "Text", item.multipier_total_value)
                                                    , new { @class = "form-control", /*id = "multipier_total_value",*/ })
                                                </div>
                                            </div>
                                        </div>
                                        @*}*@
                                        @Html.Hidden("pump_id", item.pump_id)
                                        @Html.Hidden("pump_display_id", item.pump_display_id)
                                        @Html.Hidden("advance_id", item.advance_id)
                                    }
                                    @if (ViewBag.userrole != "guest")
                                    {
                                        <br>
                                        <div class="row clearfix" align="center">
                                            <div class="col-md-2">
                                                <button type="button" class="btn btn-block btn-outline-info btn-sm" id="btndel" name="btndel" value="btndel" onclick="requiredfunc(this.id)" @*onclick="sentdelete()"*@>Delete</button>
                                            </div>
                                            <div class="col-md-2"></div>
                                            <div class="col-md-2" align="center">
                                                <button type="button" class="btn btn-block btn-success btn-sm" id="btnedi" name="btnedi" value="btnedi" onclick="requiredfunc(this.id)">Save</button>
                                            </div>
                                            <div class="col-md-2" align="center">
                                                @Html.ActionLink("Cancel", "Pump", "Pump", null, new { @class = "btn btn-block btn-outline-primary btn-sm" })
                                            </div>
                                        </div>
                                    }
