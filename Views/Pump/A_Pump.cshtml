<script src="~/bower_components/jquery/jquery.min.js"></script>

<script type="text/javascript">
    var click = 1;
    function hideAdSetting() {
        //var tanktypevalue = document.getElementById("dllTankType").value;
        if (click == "1") {
            document.getElementById('divadset').style.display = 'block';
            document.getElementById('closeadset').style.display = 'block';
            document.getElementById('openadset').style.display = 'none';
            click = click + 1;
        }
        else {
            document.getElementById('divadset').style.display = 'none';
            document.getElementById('closeadset').style.display = 'none';
            document.getElementById('openadset').style.display = 'block';
            click = click - 1;
        }
    }

    var checkadset = (function clickadset() {
        if (click == "1") {
            document.getElementById('divadset').style.display = 'none';
        }
        else {
            document.getElementById('divadset').style.display = 'block';
        }
    }());

    //var protocolList = @Html.Raw(ViewBag.getprotocol);

    function looptohidden() {
        var loopvalue = document.getElementById("ddlLoop").value;
        document.getElementById('txtLoop').value = loopvalue;

        var stringArray = new Array();
        stringArray[0] = loopvalue;

        var postData = { values: stringArray };

        $.ajax({
            type: "POST",
            url: "../Pump/getprotocol",
            data: postData,
            success: function (data) {
                if (data.protocol_id == 1) { //Gilbarco
                    $(".inarea_pumptype").remove();
                    $("#area_pumptype").append(`
                        <div class="row clearfix inarea_pumptype">
                            <div class="col-md-1"></div>
                            <div class="col-md-4"><label class="normalweight" for="item_pump_type">Pump Type: </label></div>
                            <div class="custom-control custom-radio custom-control-inline" style="margin-left:0.5%">
                                <input class="custom-control-input" data-val="true" data-val-required="The pump_type field is required." id="rdbom1" name="item.pump_type" type="radio" value="5">
                                <label class="custom-control-label normalweight" for="rdbom1">5 Digits</label>
                            </div>
                            <div class="custom-control custom-radio custom-control-inline">
                                <input class="custom-control-input" id="rdbom2" name="item.pump_type" type="radio" value="6">
                                <label class="custom-control-label normalweight" for="rdbom2">6 Digits</label>
                            </div>
                        </div>
                        <br class="inarea_pumptype">
                    `)
                }
                else {
                    $(".inarea_pumptype").remove();
                }
                document.getElementById("txtProtocol").value = data.protocol_name;
                defaultFormat(data.protocol_id);
            },
            dataType: "json",
            traditional: true
        });
    }

    //var defaultloop = (function setdefaultloop() {
    //    var loopvalue = document.getElementById("ddlLoop").value;
    //    document.getElementById('txtLoop').value = loopvalue;
    //}());

    //var defaultadset = (function setdefaultadset() {
    //    document.getElementById('ddlMulPreVol').value = 1;
    //    document.getElementById('ddlMulPreVal').value = 1;
    //    document.getElementById('ddlMulTraVol').value = 1;
    //    document.getElementById('ddlMulTraVal').value = 1;
    //    document.getElementById('ddlMulTotVol').value = 1;
    //    document.getElementById('ddlMulTotVal').value = 1;
    //}());

    var defaultindb = (function setdefaultindb() {
        var statesAvailable = @Html.Raw(ViewBag.indblist);

        if (statesAvailable === null) {   
            var new_num = 1;
            var new_pumpname = "Pump " + new_num;
            document.getElementById('txtPumpName').value = new_pumpname;
            document.getElementById('ddlLoop').value = 1; //default loop id
            document.getElementById('txtLoop').value = 1; 
            document.getElementById('txtPhyAdd').value = new_num;

            //default as Gilbarco protocal
            document.getElementById("rdbom1").checked = true;
            document.getElementById("rdbom2").checked = false;
            document.getElementById("rdbom1").disabled = false;
            document.getElementById("rdbom2").disabled = false;

            document.getElementById('ddlPumpVal').value = 2;
            document.getElementById('ddlPumpVol').value = 3;
            document.getElementById('ddlPumpPri').value = 2;
            document.getElementById('ddlPumpValTot').value = 2;
            document.getElementById('ddlPumpVolTot').value = 2;
            document.getElementById('txtStackSize').value = 100;
            document.getElementById('ddlMulPreVol').value = 1;
            document.getElementById('ddlMulPreVal').value = 1;
            document.getElementById('ddlMulTraVol').value = 1;
            document.getElementById('ddlMulTraVal').value = 1;
            document.getElementById('ddlMulTotVol').value = 1;
            document.getElementById('ddlMulTotVal').value = 1;

            document.getElementById("chkSelfAutho").checked = false;
        }
        else {
            var new_num = parseInt(statesAvailable.pump_id) + 1;
            var new_pumpname = "Pump " + new_num;
            var protocol_id = parseInt(statesAvailable.protocol_id);

            document.getElementById('txtPumpName').value = new_pumpname;
            document.getElementById('ddlLoop').value = statesAvailable.loop_id;
            document.getElementById('txtLoop').value = statesAvailable.loop_id;
            document.getElementById('txtPhyAdd').value = new_num;
            document.getElementById("txtProtocol").value = statesAvailable.pump_description;

            if (protocol_id == 1) { //Gilbarco
                var checkpumptype = (statesAvailable.pump_type).toString();

                if (checkpumptype == "5") {
                    document.getElementById("rdbom1").checked = true;
                    document.getElementById("rdbom2").checked = false;
                    document.getElementById("rdbom1").disabled = false;
                    document.getElementById("rdbom2").disabled = false;
                }
                else if (checkpumptype == "6") {
                    document.getElementById("rdbom1").checked = false;
                    document.getElementById("rdbom2").checked = true;
                    document.getElementById("rdbom1").disabled = false;
                    document.getElementById("rdbom2").disabled = false;
                }
                else {
                    document.getElementById("rdbom1").checked = false;
                    document.getElementById("rdbom2").checked = false;
                    document.getElementById("rdbom1").disabled = false;
                    document.getElementById("rdbom2").disabled = false;
                }
            }
            else {
                $(".inarea_pumptype").remove();
            }

            defaultFormat(protocol_id);

            document.getElementById('txtStackSize').value = statesAvailable.stack_limit;
            document.getElementById('ddlMulPreVol').value = statesAvailable.multipier_preset_volume;
            document.getElementById('ddlMulPreVal').value = statesAvailable.multipier_preset_value;
            document.getElementById('ddlMulTraVol').value = statesAvailable.multipier_transaction_volume;
            document.getElementById('ddlMulTraVal').value = statesAvailable.multipier_transaction_value;
            document.getElementById('ddlMulTotVol').value = statesAvailable.multipier_total_volume;
            document.getElementById('ddlMulTotVal').value = statesAvailable.multipier_total_value;

            var checkauthorize = (statesAvailable.self_mode).toString();

            if (checkauthorize == "true") {
                document.getElementById("chkSelfAutho").checked = true;
            }
            else if (checkauthorize == "false") {
                document.getElementById("chkSelfAutho").checked = false;
            }
            else { }
        }

    }());

    function addDropDown(id,value)
    {
        var opt = document.createElement("option");
        document.getElementById(id).options.add(opt);
        let i = 0;
        var text = value == 0 ? "0.0" : "0." ;

        while (i < value) {
            text += "0";
            i++;
        }
        opt.text = text;
        opt.value = value;
    }

    function defaultFormat(protocal){
        //set dropdown
        if(protocal == 1){ //Gilbarco
            //set pump price
            document.getElementById("ddlPumpPri").options.length = 0;
            addDropDown("ddlPumpPri",2);
            document.getElementById('ddlPumpPri').value = 2;

            //set pump value
            document.getElementById("ddlPumpVal").options.length = 0;
            addDropDown("ddlPumpVal",1);
            addDropDown("ddlPumpVal",2);
            document.getElementById('ddlPumpVal').value = 2;

            //set pump volume
            document.getElementById("ddlPumpVol").options.length = 0;
            addDropDown("ddlPumpVol",1);
            addDropDown("ddlPumpVol",2);
            addDropDown("ddlPumpVol",3);
            document.getElementById("ddlPumpVol").value = 3;

            //set pump total value
            document.getElementById("ddlPumpValTot").options.length = 0;
            addDropDown("ddlPumpValTot",2);
            document.getElementById('ddlPumpValTot').value = 2;

            //set pump total volume
            document.getElementById("ddlPumpVolTot").options.length = 0;
            addDropDown("ddlPumpVolTot",2);
            document.getElementById('ddlPumpVolTot').value = 2;
        }
        else if(protocal == 3 || protocal == 6){  //Tatsuno or Wayne
             //set pump price
            document.getElementById("ddlPumpPri").options.length = 0;
            addDropDown("ddlPumpPri",2);
            document.getElementById('ddlPumpPri').value = 2;
            
            //set pump value
            document.getElementById("ddlPumpVal").options.length = 0;
            addDropDown("ddlPumpVal",1);
            addDropDown("ddlPumpVal",2);
            document.getElementById('ddlPumpVal').value = 2;

            //set pump volume
            document.getElementById("ddlPumpVol").options.length = 0;
            addDropDown("ddlPumpVol",1);
            addDropDown("ddlPumpVol",2);
            addDropDown("ddlPumpVol",3);
            document.getElementById("ddlPumpVol").value = 3;

            //set pump total value
            document.getElementById("ddlPumpValTot").options.length = 0;
            addDropDown("ddlPumpValTot",2);
            document.getElementById('ddlPumpValTot').value = 2;

            //set pump total volume
            document.getElementById("ddlPumpVolTot").options.length = 0;
            addDropDown("ddlPumpVolTot",3);
            document.getElementById('ddlPumpVolTot').value = 3;
        }
        else{
            setOriginFormat(protocal);
        }
        
    }

    function defaultValTotal(val) {
        var stringArray = new Array();
        stringArray[0] = document.getElementById("ddlLoop").value;
        var postData = { values: stringArray };

        $.ajax({
            type: "POST",
            url: "../Pump/getprotocol",
            data: postData,
            success: function (data) {
                if (data.protocol_id == 1 || data.protocol_id == 3 || data.protocol_id == 6) { //Gilbarco or Tatsuno or Wayne
                    document.getElementById("ddlPumpValTot").options.length = 0;
                    addDropDown("ddlPumpValTot",val);
                    document.getElementById("ddlPumpValTot").value = val;
                }
            },
            dataType: "json",
            traditional: true
        });
    }

    function defaultVolTotal(val) {
        var stringArray = new Array();
        stringArray[0] = document.getElementById("ddlLoop").value;
        var postData = { values: stringArray };

        $.ajax({
            type: "POST",
            url: "../Pump/getprotocol",
            data: postData,
            success: function (data) {
                if (data.protocol_id == 1) { //Gilbarco
                    document.getElementById("ddlPumpVolTot").options.length = 0;
                    if(val > 2){
                        addDropDown("ddlPumpVolTot",2);
                        document.getElementById("ddlPumpVolTot").value = 2;
                    }
                    else{
                        addDropDown("ddlPumpVolTot",val);
                        document.getElementById("ddlPumpVolTot").value = val;
                    }
                }
                else if(data.protocol_id == 3 || data.protocol_id == 6){ //Tatsuno or Wayne
                    document.getElementById("ddlPumpVolTot").options.length = 0;
                    addDropDown("ddlPumpVolTot",val);
                    document.getElementById("ddlPumpVolTot").value = val;
                }
            },
            dataType: "json",
            traditional: true
        });
    }

    function setOriginFormat(protocal)
    {
        document.getElementById("ddlPumpPri").options.length = 0;
        addDropDown("ddlPumpPri",0);
        addDropDown("ddlPumpPri",1);
        addDropDown("ddlPumpPri",2);
        addDropDown("ddlPumpPri",3);
            
        document.getElementById("ddlPumpVal").options.length = 0;
        addDropDown("ddlPumpVal",0);
        addDropDown("ddlPumpVal",1);
        addDropDown("ddlPumpVal",2);
        addDropDown("ddlPumpVal",3);

        document.getElementById("ddlPumpVol").options.length = 0;
        addDropDown("ddlPumpVol",0);
        addDropDown("ddlPumpVol",1);
        addDropDown("ddlPumpVol",2);
        addDropDown("ddlPumpVol",3);

        document.getElementById("ddlPumpValTot").options.length = 0;
        addDropDown("ddlPumpValTot",0);
        addDropDown("ddlPumpValTot",1);
        addDropDown("ddlPumpValTot",2);
        addDropDown("ddlPumpValTot",3);

        document.getElementById("ddlPumpVolTot").options.length = 0;

        if(protocal.includes("Mepsan") == true){
            addDropDown("ddlPumpVolTot",1);
            addDropDown("ddlPumpVolTot",2);
            addDropDown("ddlPumpVolTot",3);
        }else{
            addDropDown("ddlPumpVolTot",0);
            addDropDown("ddlPumpVolTot",1);
            addDropDown("ddlPumpVolTot",2);
            addDropDown("ddlPumpVolTot",3);
        }
        
        var statesAvailable = @Html.Raw(ViewBag.indblist);
            
        if (statesAvailable === null) {   
            document.getElementById('ddlPumpVal').value = 2;
            document.getElementById('ddlPumpVol').value = 3;
            document.getElementById('ddlPumpPri').value = 2;
            document.getElementById('ddlPumpValTot').value = 2;
            document.getElementById('ddlPumpVolTot').value = 2;
        }else{
            document.getElementById('ddlPumpVal').value = statesAvailable.value_decimal_digit;
            document.getElementById('ddlPumpVol').value = statesAvailable.volume_decimal_digit;
            document.getElementById('ddlPumpPri').value = statesAvailable.price_decimal_digit;
            document.getElementById('ddlPumpValTot').value = statesAvailable.value_total_decimal_digit;
            document.getElementById('ddlPumpVolTot').value = statesAvailable.volume_total_decimal_digit;
        } 
    }

</script>