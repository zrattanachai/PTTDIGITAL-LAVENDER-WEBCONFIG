                            </div>
                            <!-- /.card-body -->
                        </div>
                        <!-- /.card -->
                    </div>
                    <!--/.col (right) -->
                </div>
                <!-- /.row -->
            </div><!-- /.container-fluid -->
        }
        <br>
        <div class="container-fluid">
            <div class="row mb-2">
                <div class="col-sm-6">
                    <h5>
                        Hose Number
                    </h5>
                </div>
            </div>
        </div>
        <br>
        <div class="row">
            <div class="col-12">
                <div class="card">
                    @if (ViewBag.userrole != "guest")
                    {
                        <div class="card-header">
                            <div class="row clearfix">
                                <div class="col-md-2">
                                    @Html.ActionLink("Create Hose", "A_Hose", "Pump", new { ID = pid@*, LoopID = lid*@ }, new { ID = pid, @class = "btn btn-block btn-primary"@*, LoopID = lid*@ })
                                </div>
                            </div>
                        </div>
                    }
                    <!-- /.card-header -->
                    <div class="card-body">
                        <table id="example1" class="table table-bordered table-striped dataTable" role="grid" style="width: 35%; margin:0 auto">
                            <thead>
                                <tr role="row" class="header bg-light-blue">
                                    <th rowspan="1" colspan="1" class="text-center" style="width: 25%;">Number</th>
                                    <th rowspan="1" colspan="1" class="text-center" style="width: 25%;">Grade</th>
                                    <th rowspan="1" colspan="1" class="text-center" style="width: 25%;">Tank</th>
                                    <th rowspan="1" colspan="1" class="text-center" style="width: 25%;">Settings</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    int i = 1;
                                    @foreach (HoseinAddPump hosein in ViewBag.hose)
                                    {
                                        <tr role="row" class="odd" align="center">
                                            <td class="item-id">@hosein.hose_number</td>
                                            <td>
                                                @foreach (var grade in ViewBag.hosegradeinpump)
                                                {
                                                    if (hosein.grade_id == grade.grade_id)
                                                    {
                                                        @grade.grade_name
                                                    }
                                                }
                                            </td>
                                            <td>
                                                @*@hosein.tank_id*@
                                                @foreach (var tank in ViewBag.hosetankinpump)
                                                {
                                                    if (hosein.tank_id == tank.tank_id)
                                                    {
                                                        @tank.tank_name
                                                    }
                                                }
                                            </td>
                                            <td>
                                            @if (ViewBag.userrole != "guest")
                                            {
                                                @Html.ActionLink("", "E_Hose", "Pump", new { ID = hosein.hose_id, pump = pid }, new { ID = hosein.hose_id, pump = pid, @class = "fas fa-cog changetextcolor", title = "Settings" })
                                            }
                                            else 
                                            {
                                                <span>-</span>
                                            }
                                            </td>
                                        </tr>
                                        i++;
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                    <!-- /.card-body -->
                </div>
                <!-- /.card -->
            </div>
            <!-- /.col -->
        </div>
        <!-- /.row -->
</section>

<script src="~/bower_components/jquery/jquery.min.js"></script>
<script type="text/javascript">
    var click = 1;
    function hideAdSetting() {
        if (click == "1") {
            document.getElementById('divadset').style.display = 'block';
            document.getElementById('closeadset').style.display = 'block';
            document.getElementById('openadset').style.display = 'none';
            click = click + 1;
        }
        else {
            document.getElementById('divadset').style.display = 'none';
            document.getElementById('closeadset').style.display = 'none';
            document.getElementById('openadset').style.display = 'block';
            click = click - 1;
        }
    }

    var checkadset = (function clickadset() {
        if (click == "1") {
            document.getElementById('divadset').style.display = 'none';
        }
        else {
            document.getElementById('divadset').style.display = 'block';
        }
    }());

    /* -- START LOOP -- */
    function looptohidden() {
        var loopvalue = document.getElementById("loop_id").value;
        document.getElementById('txtLoop').value = loopvalue;

        var stringArray = new Array();
        stringArray[0] = loopvalue;

        var postData = { values: stringArray };

        $.ajax({
            type: "POST",
            url: "../../Pump/getprotocol",
            data: postData,
            success: function (data) {
                
                if (data.protocol_id == 1) //Gilbarco
                {
                    $(".inarea_pumptype").remove();
                    $("#area_pumptype").append(`
                        <div class="row clearfix inarea_pumptype">
                            <div class="col-md-1"></div>
                            <div class="col-md-4"><label class="normalweight" for="item_pump_type">Pump Type: </label></div>
                            <div class="custom-control custom-radio custom-control-inline" style="margin-left:0.5%">
                                <input class="custom-control-input" data-val="true" data-val-required="The pump_type field is required." id="rdbom1" name="item.pump_type" type="radio" value="5">
                                <label class="custom-control-label normalweight" for="rdbom1">5 Digits</label>
                            </div>
                            <div class="custom-control custom-radio custom-control-inline">
                                <input class="custom-control-input" id="rdbom2" name="item.pump_type" type="radio" value="6">
                                <label class="custom-control-label normalweight" for="rdbom2">6 Digits</label>
                            </div>
                        </div>
                        <br class="inarea_pumptype">
                    `)
                }
                else
                {
                    $(".inarea_pumptype").remove();
                }
                document.getElementById("txtProtocol").value = data.protocol_name;
                defaultFormat(data.protocol_id);
            },
            dataType: "json",
            traditional: true
        });
    }

    /* -- END LOOP -- */

    /* -- START PUMP DISPLAY -- */
    function disvaltohidden() {
        var disvalvalue = document.getElementById("ddlPumpDisVal").value;
        document.getElementById('txtPumpDisVal').value = disvalvalue;
    }

