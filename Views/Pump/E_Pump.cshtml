                                                <div class="col-md-4">@Html.LabelFor(model => item.pump_type, "Pump Type: ", new { @class = "normalweight" })</div>
                                                <div class="custom-control custom-radio custom-control-inline" style="margin-left:0.5%">
                                                    @Html.RadioButtonFor(model => item.pump_type, "5", new { id = "rdbom1", name = "txtPumpType", @class = "custom-control-input" })
                                                    @Html.Label("rdbom1", "5 Digits", new { @class = "custom-control-label normalweight" })
                                                </div>
                                                <div class="custom-control custom-radio custom-control-inline">
                                                    @Html.RadioButtonFor(model => item.pump_type, "6", new { id = "rdbom2", name = "txtPumpType", @class = "custom-control-input" })
                                                    @Html.Label("rdbom2", "6 Digits", new { @class = "custom-control-label normalweight" })
