                                                                            <div class="col-12" style="margin-top: 11%;">
                                                                                <span class="info-box-more">
                                                                                    <button type="submit" class="btn btn-block btn-primary" name="submitButton" value="@ViewBag.command[i + 1, 0]" title="Clear Pump @ViewBag.command[i + 1, 0] command(s)"><i class="fas fa-eraser"></i></button>
                                                                                </span>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>
