@model List<LavenderConfig.Models.PumpCommands>

@{
    ViewData["Title"] = "StationOperation";
    ViewData["subpage"] = ViewBag.subpage;
}

@section Styles{
    <style>
        .red-background {
            background: linear-gradient(105deg ,#f8f9fa -15%,#f95353 6%,#f95353 40%,#dc3545 66.7%, #f8f9fa 67%, #214990 67.3%, #2a5fbb 90%, #2a5fbb 130%);
        }

        .green-background {
            background: linear-gradient(105deg ,#f8f9fa -15%,#58b368 6%,#58b368 40%,#28a745 66.7%, #f8f9fa 67%, #214990 67.3%, #2a5fbb 90%, #2a5fbb 130%);
        }
    </style>
}

<section class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1>
                    Station Operation
                </h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a class="changetextcolor" href="@Url.Action("HomePage", "Home")">Home</a></li>
                    <li class="breadcrumb-item active" style="text-decoration-line: underline; text-decoration-style: double;">Station Operation</li>
                </ol>
            </div>
        </div>
    </div>
</section>
<section class="content container-fluid">
        <div class="container-fluid">
            <div class="row">
                <div class="col-md-12">
