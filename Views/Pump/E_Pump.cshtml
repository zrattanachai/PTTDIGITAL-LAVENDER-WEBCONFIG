    function addDropDown(id,value)
    {
        var opt = document.createElement("option");
        document.getElementById(id).options.add(opt);
        let i = 0;
        var text = value == 0 ? "0.0" : "0." ;

        while (i < value) {
            text += "0";
            i++;
        }
        opt.text = text;
        opt.value = value;
    }

