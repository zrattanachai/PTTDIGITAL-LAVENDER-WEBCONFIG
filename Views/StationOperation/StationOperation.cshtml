                                                            @if (ViewBag.Resulttg == "active")
                                                            {
                                                                <div class="info-box-content">
                                                                    <div id="tgStopArea" class="col-7" style="margin-top: 3%;  margin-left:40%;">
                                                                        <span class="info-box-more">
                                                                            @* <button type="submit" class="btn btn-block btn-primary" name="submitButton" value="Tg_Stop" title="Stop Tank gauge service"><i class="fas fa-stop"></i></button> *@
                                                                            <button id="tgStop" type="button" class="btn btn-block btn-primary border border-light" name="tgStop" value="Tg_Stop" title="Stop Tank gauge service" onclick='actionMS("Tg_Stop", this.id)'>
                                                                                <i id="tgStopAction" class="fas fa-stop"></i>
                                                                                <i id="tgStopSpin" class="spinner-border text-light d-none" style="width: 1.3rem; height: 1.3rem;" role="status"></i>
                                                                            </button>
                                                                        </span>
                                                                    </div>
                                                                </div>
                                                            }
                                                            else
                                                            {
                                                                <div class="info-box-content">
                                                                    <div id="tgStartArea" class="col-7" style="margin-top: 3%; margin-left:40%;">
                                                                        <span class="info-box-more">
                                                                            @* <button type="submit" class="btn btn-block btn-primary" name="submitButton" value="Tg_Start" title="Start Tank gauge service"><i class="fas fa-play"></i></button> *@
                                                                            <button id="tgStart" type="button" class="btn btn-block btn-primary border border-light" name="tgStart" value="Tg_Start" title="Start Tank gauge service" onclick='actionMS("Tg_Start", this.id)'>
                                                                                <i id="tgStartAction" class="fas fa-play"></i>
                                                                                <i id="tgStartSpin" class="spinner-border text-light d-none" style="width: 1.3rem; height: 1.3rem;" role="status"></i>
                                                                            </button>
                                                                        </span>
                                                                    </div>
                                                                </div>
                                                            }
                                                        </div>
                                                    </div>

                                                    @{
                                                        var bgcolor_gaia = ViewBag.Resultgaia == "active" ? "green-background" : "red-background";
                                                    }
                                                    <div class="col-md-6 col-sm-6 col-4" id="area_gaia">
                                                        <div class="info-box gaialist @bgcolor_gaia">
                                                            <span class="info-box-icon"><img src="../../dist/img/logo-white.png" alt="GAIA Logo" width="70%"></span>
                                                            <div class="col-5">
                                                                <span class="info-box-text text-light"><b>GAIA</b></span>
                                                                @if (ViewBag.Resultgaia == "active")
                                                                {
                                                                    <span class="info-box-text text-light">Running</span>
                                                                }
                                                                else
                                                                {
                                                                    <span class="info-box-text text-light">Stopped</span>
                                                                }
                                                            </div>
                                                            @if (ViewBag.Resultgaia == "active")
                                                            {
                                                                <div class="info-box-content">
                                                                    <div id="gaiaStopArea" class="col-7" style="margin-top: 3%; margin-left:40%;">
                                                                        <span class="info-box-more">
                                                                            @* <button type="submit" class="btn btn-block btn-primary" name="submitButton" value="Gaia_Stop" title="Stop GAIA service"><i class="fas fa-stop"></i></button> *@
                                                                            <button id="gaiaStop" type="button" class="btn btn-block btn-primary border border-light" name="gaiaStop" value="Gaia_Stop" title="Stop GAIA service" onclick='actionMS("Gaia_Stop", this.id)'>
                                                                                <i id="gaiaStopAction" class="fas fa-stop"></i>
                                                                                <i id="gaiaStopSpin" class="spinner-border text-light d-none" style="width: 1.3rem; height: 1.3rem;" role="status"></i>
                                                                            </button>
                                                                        </span>
                                                                    </div>
                                                                </div>
                                                            }
                                                            else
                                                            {
                                                                <div class="info-box-content">
                                                                    <div id="gaiaStartArea" class="col-7" style="margin-top: 3%; margin-left:40%;">
                                                                        <span class="info-box-more">
                                                                            @* <button type="submit" class="btn btn-block btn-primary" name="submitButton" value="Gaia_Start" title="Start GAIA service"><i class="fas fa-play"></i></button> *@
                                                                            <button id="gaiaStart" type="button" class="btn btn-block btn-primary border border-light" name="gaiaStart" value="Gaia_Start" title="Start GAIA service" onclick='actionMS("Gaia_Start", this.id)'>
                                                                                <i id="gaiaStartAction" class="fas fa-play"></i>
                                                                                <i id="gaiaStartSpin" class="spinner-border text-light d-none" style="width: 1.3rem; height: 1.3rem;" role="status"></i>
                                                                            </button>
                                                                        </span>
                                                                    </div>
                                                                </div>
                                                            }
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="row d-flex align-items-stretch" style="flex-wrap: nowrap; overflow: auto">
                                                    @{
                                                        var bgcolor_update = ViewBag.Resultupdate == "active" ? "green-background" : "red-background";
                                                    }
                                                    <div class="col-md-6 col-sm-6 col-4" id="area_update">
                                                        <div class="info-box updatelist @bgcolor_update">
                                                            <span class="info-box-icon text-light"><i class="fas fa-arrow-alt-circle-down"></i></span>
                                                            <div class="col-5">
                                                                <span class="info-box-text text-light"><b>Update</b></span>
                                                                @if (ViewBag.Resultupdate == "active")
                                                                {
                                                                    <span class="info-box-text text-light">Running</span>
                                                                }
                                                                else
                                                                {
                                                                    <span class="info-box-text text-light">Stopped</span>
                                                                }
                                                            </div>
                                                            @if (ViewBag.Resultupdate == "active")
                                                            {
                                                                <div class="info-box-content">
                                                                    <div id="updateStopArea" class="col-7" style="margin-top: 3%; margin-left:40%;">
                                                                        <span class="info-box-more">
                                                                            @* <button type="submit" class="btn btn-block btn-primary" name="submitButton" value="Update_Stop" title="Stop Update service"><i class="fas fa-stop"></i></button> *@
                                                                            <button id="updateStop" type="button" class="btn btn-block btn-primary border border-light" name="updateStop" value="Update_Stop" title="Stop Update service" onclick='actionMS("Update_Stop", this.id)'>
                                                                                <i id="updateStopAction" class="fas fa-stop"></i>
                                                                                <i id="updateStopSpin" class="spinner-border text-light d-none" style="width: 1.3rem; height: 1.3rem;" role="status"></i>
                                                                            </button>
                                                                        </span>
                                                                    </div>
                                                                </div>
                                                            }
                                                            else
                                                            {
                                                                <div class="info-box-content">
                                                                    <div id="updateStartArea" class="col-7" style="margin-top: 3%; margin-left:40%;">
                                                                        <span class="info-box-more">
                                                                            @* <button type="submit" class="btn btn-block btn-primary" name="submitButton" value="Update_Start" title="Start Update service"><i class="fas fa-play"></i></button> *@
                                                                            <button id="updateStart" type="button" class="btn btn-block btn-primary border border-light" name="updateStart" value="Update_Start" title="Start Update service" onclick='actionMS("Update_Start", this.id)'>
                                                                                <i id="updateStartAction" class="fas fa-play"></i>
                                                                                <i id="updateStartSpin" class="spinner-border text-light d-none" style="width: 1.3rem; height: 1.3rem;" role="status"></i>
