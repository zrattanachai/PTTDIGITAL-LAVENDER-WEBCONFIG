    function sentupdateD() {

        var com = document.getElementById("rdbom1").checked;
        var usb = document.getElementById("rdbom2").checked;

        var stringArray = new Array();
        stringArray[0] = document.getElementById("txtloopidDis").value;

        if (com == true) {
            stringArray[1] = "COM " + document.getElementById("txtloopname").value;
