            //many page table
            $("#example2").DataTable(
                {
                    "lengthChange": true,
                    "searching": false,
                    "info": true,
                    "ordering": false
                }
            );
        });

        @* $(function () {
            var previousDate = new Date();
            previousDate.setMonth(previousDate.getMonth() - 6);
            var now = new Date();
            $('.datepicker').bootstrapMaterialDatePicker({
                format: 'DD-MM-YYYY',
                clearButton: false,
                weekStart: 1,
                minDate: previousDate,
                maxDate: now,
                time: true
            });

            $('.time-end').bootstrapMaterialDatePicker({
                date: false,
