@*model IEnumerable<LavenderConfig.Models.Grades>*@

@using LavenderConfig.Models
@model Tuple<List<Grades>, List<PriceProfiles>>
@*@model Tuple<Grades,PriceProfiles>*@

@{
    ViewData["Title"] = "Grade";
}

<section class="content-header">
    <h1>
        Grade
        <!--<small>Optional description</small>-->
    </h1>
</section>
<!-- Main content -->
<section class="content container-fluid">
    <!--------------------------
    | Your Page Content Here |
    -------------------------->
    <br>
    @Html.ActionLink("Create New", "A_Grade", "Add", null)
    <br>
    <br>
    <table class="table table-bordered table-striped table-hover js-basic-example dataTable" role="grid">
        <thead>
            <tr role="row" class="header bg-light-blue">
                <th rowspan="1" colspan="1" class="text-center">Grade ID</th>
                <th rowspan="1" colspan="1" class="text-center">Grade Name</th>
                <th rowspan="1" colspan="1" class="text-center">Price Level 1</th>
                <th rowspan="1" colspan="1" class="text-center">Price Level 2</th>
                <th rowspan="1" colspan="1" class="text-center">Enable</th>
                <th rowspan="1" colspan="1"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Item1)
            {
                @foreach (var itemj in Model.Item2.Where(i => i.profile_id == item.price_profile_id))
                {
                    <tr role="row" class="odd" align="center">
                        <td class="item-id">@item.grade_id</td>
                        <td>@item.grade_name</td>
                        <td>@itemj.price_level_1</td>
                        <td>@itemj.price_level_2</td>
                        <td>
                            @if (@itemj.enable == true)
                            {
                                <span class="fa fa-check" style="color:lime;"></span>
                            }
                            else
                            {
                                <span class="fa fa-times" style="color:red;"></span>
                            }
                        </td>
                        @*<td>@Html.ActionLink("Edit", "E_Grade", "Edit", new { ID = @item.grade_id, price = @item.price_profile_id }, new { ID = @item.grade_id, price = @item.price_profile_id }) | @Html.ActionLink("Delete", "D_Grade", "Delete", new { ID = @item.grade_id, price = @item.price_profile_id }, new { ID = @item.grade_id, price = @item.price_profile_id })</td>*@
                    <td>@Html.ActionLink("Details", "E_Grade", "Edit", new { ID = @item.grade_id, price = @item.price_profile_id }, new { ID = @item.grade_id, price = @item.price_profile_id })</td>
                    </tr>
                }
            }
        </tbody>
    </table>
</section>
@if (ViewBag.grademessage == null || ViewBag.grademessage == "")
{
}
else
{
    <script type="text/javascript">
            window.onload = function () {
                alert("@ViewBag.grademessage");
            };
    </script>
}