    function confirmLavModal(message, callback) {
        const modalHtml = `
            <div class="modal fade" id="bsAlertModal" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" style="padding-right: 12px;" aria-modal="true" data-backdrop='static' data-keyboard='false'>    
                <div class="modal-dialog" role="document">        
                    <div class="modal-content">            
                        <div class="modal-header">                
                            <h5 class="modal-title" id="myModalLabel">Lavender Config</h5>                
                            <button type="button" class="close deleteModal" data-dismiss="modal" aria-label="Close">                
                                <span aria-hidden="true">×</span>                
                                <span class="sr-only">Close</span>                
                            </button>            
                        </div>            
                        <div class="modal-body">                
                            <h5 id="bsAlertText">${message}</h5>          
                        </div>            
                        <div class="modal-footer">                
                            <button type="button" class="btn btn-outline-info deleteModal" data-dismiss="modal" id="deleteModal">Cancel</button>                
                            <button type="button" id="bsLavConfirmBtn" class="btn btn-outline-success">OK</button>            
                        </div>        
                    </div>    
                </div>
            </div> 
        `;

        document.body.insertAdjacentHTML('beforeend' , modalHtml);
        $('#bsAlertModal').modal('show');

        $('#bsLavConfirmBtn').click(function() {
            if(typeof callback === "function"){
                callback();
            }

            $('#bsAlertModal').modal('hide');
        });

        $(".deleteModal").click(function () {
            $(".modal-backdrop").remove();
            $('#bsAlertModal').remove();
        });
    }

    function confirmPassModal(message, callback) {
        const modalHtml = `
            <div class="modal fade" id="bsPasswordModal" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" style="padding-right: 12px;" aria-modal="true" data-backdrop='static' data-keyboard='false'>    
                <div class="modal-dialog" role="document">        
                    <div class="modal-content">            
                        <div class="modal-header">                
                            <h5 class="modal-title" id="myModalLabel">Lavender Config</h5>                
                            <button type="button" class="close deleteModal" data-dismiss="modal" aria-label="Close">                
                                <span aria-hidden="true">×</span>                
                                <span class="sr-only">Close</span>                
                            </button>            
                        </div>            
                        <div class="modal-body text-center">                
                            <h5>${message}</h5>
                            <input type="password" name="text" class="input-text" placeholder="Password" id="password" style="width:50%;" autofocus> 
                        </div>            
                        <div class="modal-footer">                
                            <button type="button" class="btn btn-outline-info deleteModal" data-dismiss="modal" id="deleteModal">Cancel</button>                
                            <button type="button" id="bsPassConfirmBtn" class="btn btn-outline-success">OK</button>            
                        </div>        
                    </div>    
                </div>
            </div>
        `;

        document.body.insertAdjacentHTML('beforeend' , modalHtml);
        $('#bsPasswordModal').modal('show');

        $('#bsPassConfirmBtn').click(function() {
            if(typeof callback === "function"){
                callback();
            }
            
            $('#bsPasswordModal').modal('hide');
        });

        $(".deleteModal").click(function () {
            $("#password").val('');
            $(".modal-backdrop").remove();
            $('#bsPasswordModal').remove();
        });
    }

    function loadingModal(message) {
        const modalHtml = `
            <div class='modal fade' id='bsLoadingModal' tabindex='-1' role='dialog' aria-labelledby='myModalLabel' aria-hidden='true' data-backdrop='static' data-keyboard='false'>
                <div class='modal-dialog modal-dialog-centered' role='document'>
                    <div class='modal-content'>
                        <div class='modal-body'>
                            <div>
                                <div class="d-flex justify-content-center">
                                    <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status"></div>
                                </div>
                                <br>
                                <div class="d-flex justify-content-center">
                                    <h5>${message}</h5>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        `;

        document.body.insertAdjacentHTML('beforeend' , modalHtml);
        $('#bsLoadingModal').modal('show');
    }

    function handleConfirmation(hardware, command) {
        confirmLavModal("Do you want to " +command+ " " +hardware+ " ?" , function(){
            confirmPassModal("Please enter your password." , function(){

                var pass = $("#password").val();

                if(pass == ""){
                    $.bsAlert.alert("Password incorrect.");
                    $("#password").val('');
                    return false;
                }
                else{
                    $.ajax({
                        type: "POST",
                        url: "../HardwareOperation/CheckPass",
                        data: { pass: pass }
                    }).done(function (res) {
                        if(res == 0){
                            var loadingMsg = "";
                    
                            if(hardware == "Lavender" && command == "power off"){
                                loadingMsg = "Powering off Lavender...";
                            }
                            else if(hardware == "Lavender" && command == "reboot"){
                                loadingMsg = "Rebooting Lavender...";
                            }
                            else if(hardware == "Modem" && command == "power off"){
                                loadingMsg = "Powering off Modem...";
                            }
                            else if(hardware == "Modem" && command == "power on"){
                                loadingMsg = "Powering on Modem...";
                            }
                            else if(hardware == "Modem" && command == "reset"){
                                loadingMsg = "Resetting Modem...";
                            }
                            else{
                                $.bsAlert.alert("Not found command.");
                                return false;
                            }

                            loadingModal(loadingMsg);
                            actionSubmit(hardware, command);
                            
                            return false;
                        }
                        else if(res == 1) {
                            $.bsAlert.alert("Password incorrect.");
                            $("#password").val('');
                            return false;
                        }
                        else{
                            $.bsAlert.alert("Can not check data.");
                            $("#password").val('');
                            return false;
                        }
                    })
                }
            });
        });
    }

    function actionSubmit(hardware, command) {       

        if(hardware == "Lavender"){
            $.ajax({
                type: "POST",
                url: "../HardwareOperation/LavenderOperation",
                data: { command: command }
            }).done(function (res) {
                $("#password").val('');
                window.location.href = '@Url.Action("HardwareOperation", "HardwareOperation")';
            }).fail(function (xhr, txtstatus, err) {
                $("#password").val('');
                window.location.href = '@Url.Action("HardwareOperation", "HardwareOperation")';
            })
        }else{ //Modem
            $.ajax({
                type: "POST",
                url: "../HardwareOperation/ModemOperation",
                data: { command: command }
            }).done(function (res) {
                $("#password").val('');
                window.location.href = '@Url.Action("HardwareOperation", "HardwareOperation")';
            }).fail(function (xhr, txtstatus, err) {
                $("#password").val('');
                window.location.href = '@Url.Action("HardwareOperation", "HardwareOperation")';
            })
        }
    }

    function editVentilation() {
        var action = '@Url.Action("E_Ventilation", "HardwareOperation")';
        window.location.href = action;
    }

