                                            <div class="col-md-1"></div>
                                            <div class="col-md-4">@Html.LabelFor(model => item.pump_name, "Pump Name: ", new { @class = "normalweight" })</div>
                                            <div class="col-md-3">
                                                @Html.TextBox("pump_name", item.pump_name, new { id = "txtPumpName", required = "required", autofocus = "", placeholder = "Pump Name", @class = "form-control", disabled = "disabled" })
                                            </div>
                                        </div>
                                        <br>
                                        <div class="row clearfix">
                                            <div class="col-md-1"></div>
                                            <div class="col-md-4">@Html.LabelFor(model => item.loop_id, "Port: ", new { @class = "normalweight" })</div>
                                            <div class="col-md-3">
                                                @Html.HiddenFor(x => item.loop_id, new { id = "txtLoop" })
                                                @Html.DropDownList("loop_id", new SelectList(ViewBag.loopinpump, "loop_id", "loop_name", item.loop_id)
                                                , new { @class = "form-control", @onchange = "looptohidden()", required = "required" })
                                            </div>
                                        </div>
                                        @*}*@
                                        <br>
                                        <div class="row clearfix">
                                            <div class="col-md-1"></div>
                                            <div class="col-md-4">@Html.LabelFor(model => item.protocol_name, "Protocol: ", new { @class = "normalweight" })</div>
                                            <div class="col-md-3">
                                                @Html.TextBox("protocol_name", item.protocol_name, new { id = "txtProtocol", required = "required", autofocus = "", placeholder = "Protocol", @class = "form-control", disabled = "disabled" })
                                            </div>
                                        </div>
                                        <br>
                                        <div class="row clearfix">
                                            <div class="col-md-1"></div>
                                            <div class="col-md-4">@Html.LabelFor(model => item.physical_address, "Physical Address: ", new { @class = "normalweight" })</div>
                                            <div class="col-md-3">
                                                @Html.TextBox("physical_address", item.physical_address, new { id = "txtPhyAdd", @type = "number", min = 1, required = "required", placeholder = "Address of Pump", @class = "form-control" })
                                            </div>
                                        </div>
                                        <br>
                                        <div id="area_pumptype">
                                            <div class="row clearfix inarea_pumptype">
