    function sentupdate() {
        var stringArray = new Array();
        stringArray[0] = document.getElementById("txtPumpID").value; // pump id
        stringArray[1] = document.getElementById("txtDisID").value; // pump display id
        stringArray[2] = document.getElementById("txtAdvID").value; // advancesetting id

        stringArray[3] = document.getElementById("txtPumpName").value;
        stringArray[4] = document.getElementById("loop_id").value;
        stringArray[5] = document.getElementById("txtPhyAdd").value;

        if (stringArray[5] == null || stringArray[5] == "") {
            $.bsAlert.alert("Please fill Physical Address with number.");
            return false;
        }
        else {

        }

        if(document.getElementById('rdbom1') == null){
            stringArray[6] = "0";
        }else{
            if (document.getElementById('rdbom1').checked) {
                stringArray[6] = document.getElementById('rdbom1').value;
            }
            else if (document.getElementById('rdbom2').checked) {
                stringArray[6] = document.getElementById('rdbom2').value;
            }
            else {
                stringArray[6] = "0";
            }

        }

        stringArray[7] = document.getElementById("txtStackSize").value;

        if ((stringArray[7] == null || stringArray[7] == "") || (stringArray[7] < 1 || stringArray[7] > 200)) {
            $.bsAlert.alert("Please fill Stack Size with number and between 1 to 200 seconds.");
            return false;
        }
        else {

        }

        stringArray[8] = document.getElementById("multipier_preset_volume").value; // advance setting
        stringArray[9] = document.getElementById("multipier_preset_value").value;
        stringArray[10] = document.getElementById("multipier_transaction_volume").value;
        stringArray[11] = document.getElementById("multipier_transaction_value").value;
        stringArray[12] = document.getElementById("multipier_total_volume").value;
        stringArray[13] = document.getElementById("multipier_total_value").value;

        stringArray[14] = document.getElementById("value_decimal_digit").value; // pump display
        stringArray[15] = document.getElementById("volume_decimal_digit").value;
        stringArray[16] = document.getElementById("price_decimal_digit").value;
        stringArray[17] = document.getElementById("value_total_decimal_digit").value;
        stringArray[18] = document.getElementById("volume_total_decimal_digit").value;

        if (document.getElementById("chkSelfAutho").checked)
        {
            stringArray[19] = true;
        }
        else
        {
            stringArray[19] = false;
        }

        if (document.getElementById("loop_id").value == 1) { //Gilbarco
            if(document.getElementById("volume_total_decimal_digit").value > 2){
                $.bsAlert.alert("Total Volume Format must below 3 decimals.");
                return false;
            }
            if(document.getElementById("price_decimal_digit").value != 2){
                $.bsAlert.alert("Price Format must be 2 decimals.");
                return false;
            }
        }

        if (document.getElementById("loop_id").value == 3) { //Tatsuno
            if(document.getElementById("price_decimal_digit").value != 2){
                $.bsAlert.alert("Price Format must be 2 decimals.");
                return false;
            }
        }

        if (document.getElementById("loop_id").value == 6) { //Wayne
            if(document.getElementById("value_total_decimal_digit").value != 2){
                $.bsAlert.alert("Total Value Format must be 2 decimals.");
                return false;
            }

            if(document.getElementById("volume_total_decimal_digit").value != 3){
                $.bsAlert.alert("Total Volume Format must be 3 decimals.");
                return false;
            }

            if(document.getElementById("price_decimal_digit").value != 2){
                $.bsAlert.alert("Price Format must be 2 decimals.");
                return false;
            }
        }

        if (document.getElementById("loop_id").value == 7) { //Mepsan
            if(document.getElementById("value_total_decimal_digit").value != 2){
                $.bsAlert.alert("Total Value Format must be 2 decimals.");
                return false;
            }
        }

        var postData = { values: stringArray };

        $.ajax({
            type: "POST",
            url: "../../Pump/UpdateListP",
            data: postData,
            success: function (data) {
                if (data.status == true) {
                    window.location.href = '@Url.Action("Pump", "Pump")';
                }
                else {

                }
            },
            dataType: "json",
            traditional: true
        });
    }

