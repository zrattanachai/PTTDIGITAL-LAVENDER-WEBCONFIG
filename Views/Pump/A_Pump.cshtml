                                        <div class="col-md-4">@Html.LabelFor(model => model.loop_id, "Port: ", new { @class = "normalweight" })</div>
                                        <div class="col-md-3">
                                            @Html.DropDownList("ddlLoop", new SelectList(ViewBag.loopinpump, "loop_id", "loop_name")
