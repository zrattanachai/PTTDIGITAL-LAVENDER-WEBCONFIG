    <!-- Flaticon -->
    <!-- Favicon icon -->
    <!-- Bootstrap Alert -->

    <link rel="stylesheet" href="~/dist/css/adminlte.css">
    <link rel="stylesheet" href="~/bower_components/fontawesome-free/css/all.min.css">
    <link rel="stylesheet" href="~/bower_components/bootstrap-icons/font/bootstrap-icons.css">
    @*<link rel="stylesheet" href="https://code.ionicframework.com/ionicons/2.0.1/css/ionicons.min.css">*@
    <link rel="stylesheet" href="~/css/ionicons.min.css">
    <link rel="stylesheet" href="~/bower_components/datatables-bs4/css/dataTables.bootstrap4.css">
    @* <link rel="stylesheet" href="~/dist/css/adminlte.css"> *@
    @* <link rel="stylesheet" href="~/css/picker/bootstrap-material-datetimepicker.css"> *@
