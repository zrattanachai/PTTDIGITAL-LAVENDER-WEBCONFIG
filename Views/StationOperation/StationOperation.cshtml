                                                        </div>
                                                    </div>
                                                </div>
                                            </form>
                                        }
                                    @*</div>*@
                                }

                                <!-- //////////////////////////////////////////////////////////////////////////////////////////////////////////////////// -->
                                @if (ViewBag.subpage == "MSAPI")
                                {
                                        @using (Html.BeginForm("S_StationOperation", "StationOperation", FormMethod.Post, new { enctype = "multipart/form-data" }))
                                        {
                                            var countpm2 = ViewBag.getpm2.Count;
                                            <br>
                                            <form role="form">
                                                <div class="row clearfix" style="margin-right: 0.5%">
                                                    <div class="col-md-9"><h4>Manage Services API &nbsp;<span class="text-danger">@ViewBag.pm2error</span></h4></div>
                                                </div>
                                                <br>
                                                <div class="row clearfix" id="area_time">
                                                    <div class="col-md-3 timelist"><h6>Last Update: @Convert.ToDateTime(DateTime.Now).ToString("dd/MM/yyyy HH:mm:ss")</h6></div>
                                                </div>
                                                <hr>
                                                <div class="row clearfix">
                                                    <label style="margin-top:0.5%; margin-left:0.5%"><b>All API Commands: </b></label>
                                                    <div class="col-md-1">
                                                        <button type="button" class="btn btn-block btn-outline-primary" name="Page_Reload" value="Page_Reload" title="Reload page" onclick='ReloadPage("MSAPI")'><i class="fas fa-sync"></i></button>
                                                    </div>
                                                    @if (ViewBag.userrole == "admin")
                                                    {
                                                        <div class="col-md-1">
                                                            <button id="RestartAllApi" type="button" class="btn btn-block btn-primary" name="RestartAllApi" value="RestartAllApi" title="Restart all API" onclick="RestartAllAPI(this.id)">
                                                                <i id="RestartAllApiAction" class="fas fa-undo"></i> 
                                                                <i id="RestartAllApiSpin" class="spinner-border text-light d-none" style="width: 1.3rem; height: 1.3rem;" role="status"></i>
                                                            </button>            
                                                        </div>
                                                        @if(ViewBag.api_lost_status == "true")
                                                        {
                                                            <div class="col-md-1">
                                                                <button id="RestoreApi" type="button" class="btn btn-block btn-primary" name="RestoreApi" value="RestoreApi" title="Restore lost API" onclick="RestoreAPI(this.id)">
                                                                    <i id="RestoreApiAction" class="fas fa-history"></i> 
                                                                    <i id="RestoreApiSpin" class="spinner-border text-light d-none" style="width: 1.3rem; height: 1.3rem;" role="status"></i>
                                                                </button>            
                                                            </div>
                                                        }
                                                        else
                                                        {
                                                            <div class="col-md-1">
                                                                <button id="RestoreApi" type="button" class="btn btn-block btn-primary" name="RestoreApi" value="RestoreApi" title="Restore lost API" disabled>
                                                                    <i id="RestoreApiAction" class="fas fa-history"></i> 
                                                                </button>            
                                                            </div>
                                                        }
                                                    }
                                                    <div class="col-md-7">
                                                        <span class="text-danger">@ViewBag.apiname_lost_msg</span>
                                                        @* <br>
                                                        <span class="text-danger">@ViewBag.apiname_db</span>
                                                        <br>
                                                        <span class="text-danger">@ViewBag.apiname_lost</span> *@
                                                    </div>
                                                </div>
                                        
                                                @if (countpm2 > 0)
                                                {
                                                    <hr>
                                                    @for (int i = 0; i < countpm2; i = i + 2)
                                                    {
                                                    <div class="row d-flex align-items-stretch" style="flex-wrap: nowrap; overflow: auto">
                                                        <div class="col-md-6 col-sm-6 col-4">
                                                            @if (ViewBag.getpm2[i].status == "online")
                                                            {
                                                                @* online *@
                                                                var pm2stoparea = ViewBag.getpm2[i].api_name + "StopArea";
                                                                var pm2stop = ViewBag.getpm2[i].api_name + "Stop";
                                                                var pm2stopaction = ViewBag.getpm2[i].api_name + "StopAction";
                                                                var pm2stopspin = ViewBag.getpm2[i].api_name + "StopSpin";

                                                                <div class='info-box pm2list green-background'>
                                                                    <span class="info-box-icon"><i class="fas fa-wrench text-light"></i></span>
                                                                    <div class="col-5">
                                                                        <span class="info-box-text text-light"><b>@ViewBag.getpm2[i].api_name</b></span>
                                                                        <span class="info-box-text text-light">Running</span>
                                                                    </div>
                                                                    <div class="info-box-content">
                                                                        <div id="@pm2stoparea" class="col-7" style="margin-top: 3%; margin-left:40%;">
                                                                            <span class="info-box-more">
                                                                                @if (ViewBag.userrole == "admin" && ViewBag.getpm2[i].api_name != "Login_Logout" && ViewBag.getpm2[i].api_name != "ManageAPI"){
                                                                                    <button id="@pm2stop" type="button" class="btn btn-block btn-primary border border-light" name="pm2Stop" value="PM2_Stop" title="Stop @ViewBag.getpm2[i].api_name service" onclick='actionMSAPI("@ViewBag.getpm2[i].status","@ViewBag.getpm2[i].id", this.id)'>
                                                                                        <i id="@pm2stopaction" class="fas fa-stop"></i>
                                                                                        <i id="@pm2stopspin" class="spinner-border text-light d-none" style="width: 1.3rem; height: 1.3rem;" role="status"></i>
                                                                                    </button>
                                                                                }
                                                                                else
                                                                                {
                                                                                    <button type="button" class="btn btn-block btn-primary border border-light" disabled>
                                                                                        <i class="fas fa-stop"></i>
                                                                                    </button>
                                                                                }
                                                                            </span>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            }
                                                            else if(ViewBag.getpm2[i].status == "stopped")
                                                            {
                                                                @* stopped *@
                                                                var pm2startarea = ViewBag.getpm2[i].api_name + "StartArea";
                                                                var pm2start = ViewBag.getpm2[i].api_name + "Start";
                                                                var pm2startaction = ViewBag.getpm2[i].api_name + "StartAction";
                                                                var pm2startspin = ViewBag.getpm2[i].api_name + "StartSpin";

                                                                <div class='info-box pm2list red-background'>
                                                                    <span class="info-box-icon"><i class="fas fa-wrench text-light"></i></span>
                                                                    <div class="col-5">
                                                                        <span class="info-box-text text-light"><b>@ViewBag.getpm2[i].api_name</b></span>
                                                                        <span class="info-box-text text-light">Stopped</span>
                                                                    </div>
                                                                    <div class="info-box-content">
                                                                        <div id="@pm2startarea" class="col-7" style="margin-top: 3%; margin-left:40%;">
                                                                            <span class="info-box-more">
                                                                                @if (ViewBag.userrole == "admin" && ViewBag.getpm2[i].api_name != "Login_Logout" && ViewBag.getpm2[i].api_name != "ManageAPI"){
                                                                                    <button id="@pm2start" type="button" class="btn btn-block btn-primary border border-light" name="pm2Start" value="PM2_Start" title="Start @ViewBag.getpm2[i].api_name service" onclick='actionMSAPI("@ViewBag.getpm2[i].status","@ViewBag.getpm2[i].id", this.id)'>
                                                                                        <i id="@pm2startaction" class="fas fa-play"></i>
                                                                                        <i id="@pm2startspin" class="spinner-border text-light d-none" style="width: 1.3rem; height: 1.3rem;" role="status"></i>
                                                                                    </button>
                                                                                }
                                                                                else
                                                                                {
                                                                                    <button type="button" class="btn btn-block btn-primary border border-light" disabled>
                                                                                        <i class="fas fa-play"></i>
