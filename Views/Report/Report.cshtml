    if (@ViewBag.reportpump != null || @ViewBag.reportpump != "")
    {
        <script type="text/javascript">
            var defaultPump = (function setdefaultPump() {
                var Pump = @ViewBag.reportpump;
                document.getElementById("ddlPump").value = Pump;
            }());
        </script>
    }
    else
    {
        <script type="text/javascript">
            var defaultPump = (function setdefaultPump() {
                document.getElementById("ddlPump").selectedIndex = "0";
