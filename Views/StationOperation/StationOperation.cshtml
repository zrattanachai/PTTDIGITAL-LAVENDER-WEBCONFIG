<script type="text/javascript">

    const disDetail = (disres) => {
        var status = (disres == 'active') ? 'Stop' : 'Start';
        $(".dislist").remove();
        $("#area_dis").append(`
            <div class="info-box dislist ${(disres == 'active') ? 'green-background' : 'red-background'}">
                <span class="info-box-icon text-light"><i class="fas fa-gas-pump"></i></span>
                <div class="col-5">
                    <span class="info-box-text text-light"><b>Dispenser</b></span>
                    <span class="info-box-text text-light">${(disres == 'active') ? 'Running' : 'Stopped'}</span>
                </div>
                <div class="info-box-content">
                    <div id="dis${status}Area" class="col-7" style="margin-top: 3%; margin-left:40%;">
                        <span class="info-box-more">
                            <button id="dis${status}" type="button" class="btn btn-block btn-primary border border-light" name="dis${status}" value="Dis_${status}" title="${status} dispenser service" onclick='actionMS("Dis_${status}", "dis${status}")'>
                                <i id="dis${status}Action" class="fas fa-${(disres == 'active') ? 'stop' : 'play'}"></i>
                                <i id="dis${status}Spin" class="spinner-border text-light d-none" style="width: 1.3rem; height: 1.3rem;" role="status"></i>
                            </button>
                        </span>
                    </div>
                </div>
            </div>
        `)
    }

    const monDetail = (monres) => {
        var status = (monres == 'active') ? 'Stop' : 'Start';
        $(".monlist").remove();
        $("#area_mon").append(`
            <div class="info-box monlist ${(monres == 'active') ? 'green-background' : 'red-background'}">
                <span class="info-box-icon text-light"><i class="fas fa-desktop"></i></span>
                <div class="col-5">
                    <span class="info-box-text text-light"><b>Monitor</b></span>
                    <span class="info-box-text text-light">${(monres == 'active') ? 'Running' : 'Stopped'}</span>
                </div>
                <div class="info-box-content">
                    <div id="mon${status}Area" class="col-7" style="margin-top: 3%; margin-left:40%;">
                        <span class="info-box-more">
                            <button id="mon${status}" type="button" class="btn btn-block btn-primary border border-light" name="mon${status}" value="Mon_${status}" title="${status} monitor service" onclick='actionMS("Mon_${status}", "mon${status}")'>
                                <i id="mon${status}Action" class="fas fa-${(monres == 'active') ? 'stop' : 'play'}"></i>
                                <i id="mon${status}Spin" class="spinner-border text-light d-none" style="width: 1.3rem; height: 1.3rem;" role="status"></i>
                            </button>
                        </span>
                    </div>
                </div>
            </div>
        `)
    }

    const tgDetail = (tgres) => {
        var status = (tgres == 'active') ? 'Stop' : 'Start';
        $(".tglist").remove();
        $("#area_tg").append(`
            <div class="info-box tglist ${(tgres == 'active') ? 'green-background' : 'red-background'}">
                <span class="info-box-icon text-light"><i class="fas fa-tachometer-alt"></i></span>
                <div class="col-5">
                    <span class="info-box-text text-light"><b>Tank Gauge</b></span>
                    <span class="info-box-text text-light">${(tgres == 'active') ? 'Running' : 'Stopped'}</span>
                </div>
                <div class="info-box-content">
                    <div id="tg${status}Area" class="col-7" style="margin-top: 3%; margin-left:40%;">
                        <span class="info-box-more">
                            <button id="tg${status}" type="button" class="btn btn-block btn-primary border border-light" name="tg${status}" value="Tg_${status}" title="${status} tank gauge service" onclick='actionMS("Tg_${status}", "tg${status}")'>
                                <i id="tg${status}Action" class="fas fa-${(tgres == 'active') ? 'stop' : 'play'}"></i>
                                <i id="tg${status}Spin" class="spinner-border text-light d-none" style="width: 1.3rem; height: 1.3rem;" role="status"></i>
                            </button>
                        </span>
                    </div>
                </div>
            </div>
        `)
    }

    const gaiaDetail = (gaiares) => {
        var status = (gaiares == 'active') ? 'Stop' : 'Start';
        $(".gaialist").remove();
        $("#area_gaia").append(`
            <div class="info-box gaialist ${(gaiares == 'active') ? 'green-background' : 'red-background'}">
                <span class="info-box-icon"><img src="../../dist/img/logo-white.png" alt="GAIA Logo" width="70%"></span>
                <div class="col-5">
                    <span class="info-box-text text-light"><b>GAIA</b></span>
                    <span class="info-box-text text-light">${(gaiares == 'active') ? 'Running' : 'Stopped'}</span>
                </div>
                <div class="info-box-content">
                    <div id="gaia${status}Area" class="col-7" style="margin-top: 3%; margin-left:40%;">
                        <span class="info-box-more">
                            <button id="gaia${status}" type="button" class="btn btn-block btn-primary border border-light" name="gaia${status}" value="Gaia_${status}" title="${status} Gaia service" onclick='actionMS("Gaia_${status}", "gaia${status}")'>
                                <i id="gaia${status}Action" class="fas fa-${(gaiares == 'active') ? 'stop' : 'play'}"></i>
                                <i id="gaia${status}Spin" class="spinner-border text-light d-none" style="width: 1.3rem; height: 1.3rem;" role="status"></i>
                            </button>
                        </span>
                    </div>
                </div>
            </div>
        `)
    }

    const updateDetail = (updateres) => {
        var status = (updateres == 'active') ? 'Stop' : 'Start';
        $(".updatelist").remove();
        $("#area_update").append(`
            <div class="info-box updatelist ${(updateres == 'active') ? 'green-background' : 'red-background'}">
                <span class="info-box-icon text-light"><i class="fas fa-arrow-alt-circle-down"></i></span>
                <div class="col-5">
                    <span class="info-box-text text-light"><b>Update</b></span>
                    <span class="info-box-text text-light">${(updateres == 'active') ? 'Running' : 'Stopped'}</span>
                </div>
                <div class="info-box-content">
                    <div id="update${status}Area" class="col-7" style="margin-top: 3%; margin-left:40%;">
                        <span class="info-box-more">
                            <button id="update${status}" type="button" class="btn btn-block btn-primary border border-light" name="update${status}" value="Update_${status}" title="${status} Update service" onclick='actionMS("Update_${status}", "update${status}")'>
                                <i id="update${status}Action" class="fas fa-${(updateres == 'active') ? 'stop' : 'play'}"></i>
                                <i id="update${status}Spin" class="spinner-border text-light d-none" style="width: 1.3rem; height: 1.3rem;" role="status"></i>
                            </button>
                        </span>
                    </div>
                </div>
            </div>
        `)
    }

    const timeDetail = (timeres) => {
        $(".timelist").remove();
        $("#area_time").append(`
            <div class="col-md-3 timelist"><h6>Last Update: ${timeres}</h6></div>
        `)
    }

    var myVarDis = setInterval(myFuncDis, 300000);

    var myVarMon = setInterval(myFuncMon, 300000);

    var myVarTg = setInterval(myFuncTg, 300000);

    var myVarGaia = setInterval(myFuncGaia, 300000);

    var myVarUpdate = setInterval(myFuncUpdate, 300000);

    var myVarTime = setInterval(myFuncTime, 300000);

    var myVarPM2 = setInterval(myFuncPM2, 300000);

    function myFuncDis() {
        $.ajax({
            type: "POST",
            url: "../StationOperation/UpdateDispenserStatus"
        }).done(function (disres) {
            disDetail(disres);
        });
    }

    function myFuncMon() {
        $.ajax({
            type: "POST",
            url: "../StationOperation/UpdateMonitorStatus"
        }).done(function (monres) {
            monDetail(monres);
        });
    }

    function myFuncTg() {
        $.ajax({
            type: "POST",
            url: "../StationOperation/UpdateTankgaugeStatus"
        }).done(function (tgres) {
            tgDetail(tgres);
        });
    }

    function myFuncGaia() {
        $.ajax({
            type: "POST",
            url: "../StationOperation/UpdateGaiaStatus"
        }).done(function (gaiares) {
            gaiaDetail(gaiares);
        });
    }

    function myFuncUpdate() {
        $.ajax({
            type: "POST",
            url: "../StationOperation/UpdateUpdateStatus"
        }).done(function (updateres) {
            updateDetail(updateres);
        });
    }

    function myFuncTime() {
        $.ajax({
            type: "POST",
            url: "../StationOperation/UpdateTime"
        }).done(function (timeres) {
            timeDetail(timeres);
        });
    }

    function myFuncPM2() {
        if("@ViewBag.subpage" == "MSAPI"){
            window.location.href = '@Url.Action("StationOperation", "StationOperation",new { subpage = "MSAPI" })';
        }
    }

    function actionMS(submitButton, buttonid) {
        document.getElementById(buttonid).disabled = true; 
        document.getElementById(buttonid + "Action").classList.add("d-none");
        document.getElementById(buttonid + "Spin").classList.remove("d-none");
        
        $.ajax({
            type: "POST",
            url: "../StationOperation/S_StationOperation",
            data: { submitButton : submitButton }
        }).done(function (res) {
            window.location.href = '@Url.Action("StationOperation", "StationOperation",new { subpage = "MS" })';
        })
    }

    function actionMSAPI(status, idapi, buttonid) {
        document.getElementById(buttonid).disabled = true; 
        document.getElementById(buttonid + "Action").classList.add("d-none");
        document.getElementById(buttonid + "Spin").classList.remove("d-none");

        var command = status == "stopped" ? "start": "stop";
        
        $.ajax({
            type: "POST",
            url: "../StationOperation/StartStopPM2",
            data: { command: command, idapi: idapi }
        }).done(function (res) {
            window.location.href = '@Url.Action("StationOperation", "StationOperation",new { subpage = "MSAPI" })';
        })
    }

    function RestoreAPI(buttonid) {
        $.bsAlert.confirm("Do you want to restore lost api ?", function () {
            document.getElementById(buttonid).disabled = true; 
            document.getElementById(buttonid + "Action").classList.add("d-none");
            document.getElementById(buttonid + "Spin").classList.remove("d-none");

            $.ajax({
                type: "POST",
                url: "../StationOperation/RestoreAPI",
            }).done(function (res) {
                window.location.href = '@Url.Action("StationOperation", "StationOperation",new { subpage = "MSAPI" })';
            })
        });
    }

    function RestartAllAPI(buttonid) {
        $.bsAlert.confirm("Do you want to restart all api ?", function () {
            document.getElementById(buttonid).disabled = true; 
            document.getElementById(buttonid + "Action").classList.add("d-none");
            document.getElementById(buttonid + "Spin").classList.remove("d-none");

            $.ajax({
                type: "POST",
                url: "../StationOperation/RestartAllAPI",
            }).done(function (res) {
                window.location.href = '@Url.Action("StationOperation", "StationOperation",new { subpage = "MSAPI" })';
            })
        });
    }

    function ReloadPage(subpage) {
        var action = '@Url.Action("StationOperation", "StationOperation",new { subpage = "_subpage_" })';
        var action_page = action.replace("_subpage_", subpage);
       
        window.location.href = action_page;
    }

</script>