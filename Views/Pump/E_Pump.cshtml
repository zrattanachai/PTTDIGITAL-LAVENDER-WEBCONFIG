@model IEnumerable<LavenderConfig.Models.AddPumpModel>
@using LavenderConfig.Models;

@{
    ViewData["Title"] = "Pump";
    ViewData["SubTitle"] = "Edit Pump";
    int pid = 0;
    //int lid = 0;
}

<section class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1>
                    Edit Pump
                </h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a class="changetextcolor" href="@Url.Action("HomePage", "Home")">Home</a></li>
                    <li class="breadcrumb-item"><a class="changetextcolor" href="@Url.Action("Pump", "Pump")">@ViewData["Title"]</a></li>
                    <li class="breadcrumb-item active" style="text-decoration-line: underline; text-decoration-style: double;">@ViewData["SubTitle"]</li>
                </ol>
            </div>
        </div>
    </div><!-- /.container-fluid -->
</section>

<section class="content container-fluid">
        @using (Html.BeginForm("E_Pump", "Pump", FormMethod.Post, new { enctype = "multipart/form-data" }))
        {
            <div class="row clearfix">
                <div class="col-md-4"><h5>&nbsp;&nbsp;Pump</h5></div>
            </div>
            <br>
            <div class="container-fluid">
                <div class="row">
                    <div class="col-md-12">
                        <!-- general form elements disabled -->
                        <div class="card card-primary">
                            <div class="card-body">
                                <form role="form">
                                    <br>
                                    @foreach (var item in Model)
                                    {
                                        pid = item.pump_id;
                                        @Html.HiddenFor(x => item.pump_id, new { id = "txtPumpID" })
                                        @Html.HiddenFor(x => item.pump_display_id, new { id = "txtDisID" })
                                        @Html.HiddenFor(x => item.advance_id, new { id = "txtAdvID" })
