                                            </div>
                                            <br class="inarea_pumptype">
                                        </div>
                                        <div class="row clearfix">
                                            <div class="col-md-1"></div>
                                            <div class="col-md-4">@Html.LabelFor(model => item.value_decimal_digit, "Pump Value Format: ", new { @class = "normalweight" })</div>
                                            <div class="col-md-3">
                                                @{
                                                    List<SelectListItem> PumpDisNonTotListItems = new List<SelectListItem>();
                                                    PumpDisNonTotListItems.Add(new SelectListItem
                                                    {
                                                        Text = "0",
                                                        Value = "0"
                                                    });
                                                    PumpDisNonTotListItems.Add(new SelectListItem
                                                    {
                                                        Text = "0.0",
                                                        Value = "1"
                                                    });
                                                    PumpDisNonTotListItems.Add(new SelectListItem
                                                    {
                                                        Text = "0.00",
                                                        Value = "2"
                                                    });
                                                    PumpDisNonTotListItems.Add(new SelectListItem
                                                    {
                                                        Text = "0.000",
