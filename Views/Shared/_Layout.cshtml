    <script src="~/bower_components/bootstrap-datetimepicker/js/bootstrap-datetimepicker.min.js"></script> *@
    <script src="~/bower_components/daterangepicker-master/daterangepicker.js"></script>
    <script src="~/dist/js/bootstrap-alert.js"></script>
