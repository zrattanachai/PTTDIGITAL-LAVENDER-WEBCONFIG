@model LavenderConfig.Models.AddHoseModel;

@{
    ViewData["Title"] = "Pump";
    ViewData["SubTitle"] = "Edit Pump";
    ViewData["SubTitle_1"] = "Create Hose";
}

<section class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1>
                    Create Hose
                </h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a class="changetextcolor" href="@Url.Action("HomePage", "Home")">Home</a></li>
                    <li class="breadcrumb-item"><a class="changetextcolor" href="@Url.Action("Pump", "Pump")">@ViewData["Title"]</a></li>
                    <li class="breadcrumb-item"><a class="changetextcolor" href="@Html.Raw(@Url.Action("E_Pump", "Pump", new { @ID = ViewBag.id, @disID = ViewBag.disid, @loopID = ViewBag.loopid }))">@ViewData["SubTitle"]</a></li>
                    <li class="breadcrumb-item active" style="text-decoration-line: underline; text-decoration-style: double;">@ViewData["SubTitle_1"]</li>
                </ol>
            </div>
        </div>
    </div><!-- /.container-fluid -->
</section>
<section class="content container-fluid">
        @using (Html.BeginForm("A_Hose", "Pump", FormMethod.Post, new { enctype = "multipart/form-data" }))
        {
            <div class="container-fluid">
                <div class="row">
                    <div class="col-md-12">
                        <!-- general form elements disabled -->
                        <div class="card card-primary">
                            <div class="card-body">
                                <form role="form">
                                    <div class="row clearfix">
                                        <div class="col-md-1">
                                            <button type="button" value="addhose" onclick="fncAddHose()" class="btn btn-block btn-outline-primary">Add</button>
                                        </div>
                                    </div>
                                    <div id="divadd">
                                        <div id="divrow" @*class="divrow"*@>
                                            <hr>
                                            <div class="row clearfix">
                                                <div class="col-md-1"></div>
                                                <div class="col-md-4">@Html.LabelFor(model => model.pump_id, "Pump: ", new { @class = "normalweight" })</div>
                                                <div class="col-md-3">
                                                    @Html.DropDownList("ddlpump", new SelectList(ViewBag.pumpinhose, "pump_id", "pump_name")
                                                    , new { @class = "form-control", @onchange = "pumptohidden()", disabled = "disabled" })
                                                    @Html.HiddenFor(model => model.pump_id, new { id = "txtpump" })
                                                </div>
                                                <div class="col-md-1" id="divbtn">
                                                    <button type="button" id="btndel" value="deletehose" onclick="fncDeleteHose(this.parentNode.parentNode.parentNode.id)" class="btn btn-block btn-outline-info" @*disabled*@ >Delete</button>
                                                </div>
                                            </div>
                                            <br>
                                            <div class="row clearfix">
                                                <div class="col-md-1"></div>
                                                <div class="col-md-4">@Html.LabelFor(model => model.hose_number, "Hose Number: ", new { @class = "normalweight" })</div>
                                                <div class="col-md-3">
                                                    @Html.TextBoxFor(model => model.hose_number, new { id = "txthosenumber", required = "required", autofocus = "", placeholder = "Number Only", @type="number", min = 1, @class = "form-control" })
                                                </div>
                                            </div>
                                            <br>
                                            <div class="row clearfix">
                                                <div class="col-md-1"></div>
                                                <div class="col-md-4">@Html.LabelFor(model => model.grade_id, "Grade: ", new { @class = "normalweight" })</div>
                                                <div class="col-md-3">
                                                    @Html.DropDownList("ddlgrade", new SelectList(ViewBag.gradeinhose, "grade_id", "grade_name")
                                                    , new { @class = "form-control", @onchange = "gradetohidden()" })
                                                    @Html.HiddenFor(model => model.grade_id, new { id = "txtgrade" })
                                                </div>
                                            </div>
                                            <br>
                                            <div class="row clearfix">
                                                <div class="col-md-1"></div>
                                                <div class="col-md-4">@Html.LabelFor(model => model.tank_id, "Tank: ", new { @class = "normalweight" })</div>
                                                <div class="col-md-3">
                                                    @Html.DropDownList("ddltank", new SelectList(ViewBag.tankinhose, "tank_id", "tank_name")
                                                    , new { @class = "form-control", @onchange = "tanktohidden()" })
                                                    @Html.HiddenFor(model => model.tank_id, new { id = "txttank" })
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <br>
                                    <br>
                                    <div class="row clearfix">
                                        <div class="col-md-4"></div>
                                        <div class="col-md-2" align="center">
                                            <button type="button" class="btn btn-block btn-success btn-sm" value="A_Hose" onclick="sentadd()">Create</button>
                                        </div>
                                        <div class="col-md-2">
                                            @Html.ActionLink("Cancel", "E_Pump", "Pump", new { ID = @ViewBag.id, disID = ViewBag.disid, loopID = ViewBag.loopid }, new { ID = @ViewBag.id, disID = ViewBag.disid, loopID = ViewBag.loopid, @class = "btn btn-block btn-outline-primary btn-sm" })
                                        </div>
                                    </div>
                                </form>
                            </div>
                            <!-- /.card-body -->
                        </div>
                        <!-- /.card -->
                    </div>
                    <!--/.col (right) -->
                </div>
                <!-- /.row -->
            </div><!-- /.container-fluid -->
        }
</section>


<script type="text/javascript">
    function pumptohidden() {
        var pumpvalue = document.getElementById("ddlpump").value;
        document.getElementById('txtpump').value = pumpvalue;
    }

    var defaultpump = (function setdefaultpump() {
        var pumpvalue = document.getElementById('ddlpump').selectedOptions[0].value;
        document.getElementById("ddlpump").value = pumpvalue;
        document.getElementById('txtpump').value = pumpvalue;
    }());

    function gradetohidden() {
        var gradevalue = document.getElementById("ddlgrade").value;
        document.getElementById('txtgrade').value = gradevalue;
    }

    var defaultgrade = (function setdefaultgrade() {
        var gradevalue = document.getElementById('ddlgrade').selectedOptions[0].value;
        document.getElementById("ddlgrade").value = gradevalue;
        document.getElementById('txtgrade').value = gradevalue;
    }());

    function tanktohidden() {
        var tankvalue = document.getElementById("ddltank").value;
        document.getElementById('txttank').value = tankvalue;
    }

    var defaulttank = (function setdefaulttank() {
        var tankvalue = document.getElementById('ddltank').selectedOptions[0].value;
        document.getElementById("ddltank").value = tankvalue;
        document.getElementById('txttank').value = tankvalue;
    }());
</script>
@if (ViewBag.pumpmessage == null || ViewBag.pumpmessage == "")
{
}
else
{
    if (ViewBag.perpage == "1")
    {
        <script type="text/javascript">
            window.onload = function () {
                $.bsAlert.alert("@ViewBag.pumpmessage");
            };
        </script>
    }
}
<script type="text/javascript">

    var cnode = 1;

    function fncAddHose() 
    {
        cnode++;

        $("#divrow").attr('id', 'divrow-1');
        var itm = document.getElementById("divrow-1");
        var cln = itm.cloneNode(true);
        cln.id = 'divrow-' + cnode;
    
        document.getElementById("divadd").appendChild(cln);
        document.getElementById('divrow-' + cnode).getElementsByTagName("input")[1].value = ""; //Clear Value Of HoseNumber After Clone.
    }

    function fncDeleteHose(data)
    {
        var sentdata = data;

        $.bsAlert.confirm("Do you want to delete this hose ?", function () {
            fncDelThisHose(sentdata);
        });
    }

    function fncDelThisHose(data)
    {
        var subdata = data.substring(7);

        if (subdata != 1) {
            var itm = this.document.getElementById("divrow-" + subdata);

            if (itm != null)
            {
                document.getElementById("divrow-" + subdata).remove();
            }
            else
            {
                return false;
            }

        }
        else
        {
            $.bsAlert.alert("This hose can't delete.");
            return false;
        }
    }

    function sentadd()
    {
        var stringArray = new Array();
        var hoseArray = new Array();

        var div = document.getElementById("divadd");
        var input = div.getElementsByTagName("input");
        var select = div.getElementsByTagName("select");
        var inputcount = input.length - 1;
        var rowset = input.length / 4;
        //var rowsetselect = select.length / 3;
        var count = 0;
        var countselect = 0;
        var counthose = 0;
        var countinput = 0;

        var allhose = 0;
        var chose = 0;
        var ccompareh = 1;
        var ihose = 1;
        var icompareh = 1;
        var inputposition = 0;

        var numbers = /^[0-9]+$/;

        for (i = 1; i <= rowset; i++)
        {
            stringArray[count] = document.getElementsByTagName("select")[countselect].value;

            if (document.getElementsByTagName("input")[count + 1].value >= 1 && document.getElementsByTagName("input")[count + 1].value.match(numbers))
            {
                stringArray[count + 1] = document.getElementsByTagName("input")[count + 1].value;
                hoseArray[counthose] = document.getElementsByTagName("input")[count + 1].value;
            }
            else
            {
                $.bsAlert.alert("Hose Number is a number and no less than 1.");
                document.getElementsByTagName("input")[count + 1].value = null;
                return false;
            }

            stringArray[count + 2] = document.getElementsByTagName("select")[countselect + 1].value;
            stringArray[count + 3] = document.getElementsByTagName("select")[countselect + 2].value;

            count = count + 4;
            countselect = countselect + 3;
            counthose = counthose + 1;
        }

        allhose = hoseArray.length;
        
        if (allhose > 1)
        {
            for (cc = ihose; cc < allhose; cc++)
            {
                for (c = icompareh; c < allhose; c++) {
                    if (hoseArray[chose] == hoseArray[ccompareh]) {

                        inputposition = c + 1;
                        inputposition = (inputposition * 4) - 2;
                        $.bsAlert.alert("Hose Number is duplicate.");
                        console.log(document.getElementsByTagName("input")[inputposition].value);
                        return false;
                    }
                    else {

                    }
                    ccompareh++;
                }
                chose++;
                ccompareh = chose + 1;
                ihose++;
                icompareh++;
                countinput = countinput + 4;
            }
        }
        else
        {

        }

        var postData = { values: stringArray };

        $.ajax({
            type: "POST",
            url: "../../Pump/InsertHose",
            data: postData,
            success: function (data) {
                if (data.status == true) {
                    @* window.location.href = '@Url.Action("E_Pump", "Pump", new { @ID = @ViewBag.id, @disID = @ViewBag.disid, @loopID = @ViewBag.loopid })'; *@
                    window.location.href = "@Html.Raw(@Url.Action("E_Pump", "Pump", new { @ID = ViewBag.id, @disID = ViewBag.disid, @loopID = ViewBag.loopid }))";
            }
            else {
                    $.bsAlert.alert(data.message);
            }
            },
            dataType: "json",
            traditional: true
        });

    }
</script>